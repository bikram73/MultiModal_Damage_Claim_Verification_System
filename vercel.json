{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/claims",
      "destination": "/api/claims"
    },
    {
      "source": "/api/metrics",
      "destination": "/api/metrics"
    },
    {
      "source": "/api/run",
      "destination": "/api/run"
    },
    {
      "source": "/claims_data.json",
      "destination": "/code/claims_data.json"
    },
    {
      "source": "/dataset/images/:path*",
      "destination": "/dataset/images/:path*"
    },
    {
      "source": "/",
      "destination": "/code/index.html"
    }
  ],
  "functions": {
    "api/claims.py": {
      "runtime": "python3.9",
      "maxDuration": 10
    },
    "api/metrics.py": {
      "runtime": "python3.9",
      "maxDuration": 10
    },
    "api/run.py": {
      "runtime": "python3.9",
      "maxDuration": 60
    }
  }
}